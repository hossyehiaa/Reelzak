// ==========================================================================
// CGLAB — Prisma Schema
// ==========================================================================
// Models:
//   User    — clients + admins (role-based)
//   Order   — reel orders (brief -> delivery)
//   OrderStatusUpdate — audit trail of status changes
//   Package — pricing tiers (1 / 4 / 10 reels per month)
// --------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Production: PostgreSQL on Neon
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// USER
// ---------------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String? // null if using OAuth (future-proof)
  role      Role     @default(CLIENT)
  brandName String? // convenience cache of the latest brand name used in briefs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  statusUpdates OrderStatusUpdate[]
  verifiedPayments Order[] @relation("PaymentVerifier")

  @@index([email])
}

enum Role {
  CLIENT
  ADMIN
}

// ---------------------------------------------------------------------------
// ORDER
// ---------------------------------------------------------------------------
model Order {
  id              String         @id @default(cuid())
  orderNumber     String         @unique // human-friendly: CGL-2026-0001
  clientId        String
  client          User           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  brandName       String
  industry        String?
  briefDetails    String         // JSON-encoded brief (objective, style, audience, message, refs, etc.)
  status          OrderStatus    @default(PENDING)
  deadline        DateTime?
  deliveryFileUrl String?        // populated by admin when status -> DELIVERED
  deliveryFileName String?
  // --- Payment (Task 3) ---
  paymentPackage  String?        // "single" | "monthly-4" | "monthly-10"
  paymentReceiptUrl String?      // base64 data URL of the uploaded receipt screenshot
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentVerifiedAt DateTime?
  paymentVerifiedById String?
  paymentVerifiedBy User?        @relation("PaymentVerifier", fields: [paymentVerifiedById], references: [id])
  // --- Client revision (Task 4) ---
  clientApprovedAt DateTime?     // set when client clicks "Approve"
  clientRevisionNotes String?    // set when client clicks "Request Revision" + submits feedback
  clientRevisionRequestedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  statusUpdates   OrderStatusUpdate[]

  @@index([clientId])
  @@index([status])
  @@index([deadline])
  @@index([paymentStatus])
}

enum OrderStatus {
  PENDING          // brief submitted, awaiting team pickup
  IDEATION         // team is researching/ideating concepts
  AI_GENERATION    // generating assets with AI
  EDITING          // assembling the final reel
  READY_FOR_REVIEW // first cut sent to client for review
  DELIVERED        // final file attached, order closed
}

enum PaymentStatus {
  PENDING   // receipt uploaded, awaiting admin verification
  VERIFIED  // admin confirmed the payment
  REJECTED  // admin rejected the receipt (wrong amount, unclear, etc.)
}

// ---------------------------------------------------------------------------
// ORDER STATUS UPDATE — audit trail
// ---------------------------------------------------------------------------
model OrderStatusUpdate {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus
  toStatus   OrderStatus
  changedById String?
  changedBy  User?        @relation(fields: [changedById], references: [id])
  note       String?
  createdAt  DateTime     @default(now())

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// PACKAGE — pricing tiers (single source of truth for the pricing section)
// ---------------------------------------------------------------------------
model Package {
  id        String   @id @default(cuid())
  slug      String   @unique // "single" | "monthly-4" | "monthly-10"
  name      String
  tagline   String?
  priceUsd  Int      // in whole dollars; display as $price/mo
  reelCount Int      // number of reels included
  cadence   String   @default("one-time") // "one-time" | "monthly"
  popular   Boolean  @default(false)
  features  String   // JSON-encoded array of feature strings
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
